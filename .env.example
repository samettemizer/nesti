# ── Hermes-3– Primary Planner ──────────────────────────────────
# ollama pull hermes3:8b
HERMES3_LLM_ENABLED=false
HERMES3_LLM_URL=http://192.168.100.4:11434/v1
HERMES3_LLM_MODEL=hermes3:8b
HERMES3_LLM_TIMEOUT=1800

# ── DeepSeek API – Mid-tier Fallback (Planner & Coder) ───────────────────────
# Register at: https://platform.deepseek.com
# deepseek-chat is the cost-efficient general model (V3 class)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=600

# ── Anthropic Claude – Last-resort Fallback ───────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Telegram Notifications ────────────────────────────────────────────────────
# 1. Create a bot with @BotFather  → get TELEGRAM_BOT_TOKEN
# 2. Add bot to your chat/group   → get TELEGRAM_CHAT_ID via @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Qwen3:30b (192.168.100.2) – Primary Code Generator (if enabled) ──────────
LOCAL_LLM_ENABLED=false
LOCAL_LLM_URL=http://192.168.100.2:11434/v1
LOCAL_LLM_MODEL=qwen3:30b-a3b-q4_K_M
LOCAL_LLM_TIMEOUT=1800
# Total attempts = MAX_CODE_RETRIES + 1  (maps 1:1 to 3 coder tiers)
MAX_CODE_RETRIES=2

# ── Redmine ───────────────────────────────────────────────────────────────────
REDMINE_URL=http://192.168.100.1:3000
REDMINE_API_KEY=your_redmine_api_key_here
REDMINE_PROJECT_ID=test-proje-b
REDMINE_IN_PROGRESS_STATUS_ID=2
REDMINE_CLOSED_STATUS_ID=5
REDMINE_NEW_STATUS_ID=1

# ── GitLab ────────────────────────────────────────────────────────────────────
GITLAB_SSL_VERIFY=true
GITLAB_URL=https://gitlab.yourdomain.com
GITLAB_TOKEN=your_gitlab_personal_access_token_here
GITLAB_PROJECT_PATH=ai/hello-world
GITLAB_USE_SSH=false
GITLAB_REPO_SSH=git@gitlab.yourdomain.com:ai/hello-world.git
GITLAB_REPO_HTTPS=https://gitlab.yourdomain.com/ai/hello-world.git
GITLAB_DEFAULT_BRANCH=main

# ── Docker Sandbox ────────────────────────────────────────────────────────────
DOCKER_SANDBOX_IMAGE=hello-world-sandbox
DOCKER_SANDBOX_WORKDIR=/app
DOCKER_SANDBOX_TIMEOUT=120

# ── Redis (Conversation History) ──────────────────────────────────────────────
# Default: internal Docker Redis (service name = ai-dev-redis)
# Override to use an external Redis instance:
# REDIS_URL=redis://user:password@192.168.X.X:6379/0
REDIS_URL=redis://ai-dev-redis:6379/0
CONVERSATION_TTL_DAYS=7

# ── Database (read-only reference – AI never modifies schema) ─────────────────
DB_HOST=192.168.100.3
DB_PORT=3306
DB_NAME=misal
DB_USER=root
DB_PASSWORD=your_db_password_here

# ── Skill Loading ─────────────────────────────────────────────────────────────
# Set to 1 to inject skill docs into the coding prompt (for large-context providers).
INCLUDE_SKILLS_IN_CODE_PROMPT=1

# ── Workspace ─────────────────────────────────────────────────────────────────
WORKSPACE_PATH=/tmp/ai-developer-workspace
LOG_LEVEL=INFO
